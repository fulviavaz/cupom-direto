generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Store {
  id           Int      @id @default(autoincrement())
  name         String
  slug         String   @unique
  logoUrl      String?
  affiliateUrl String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}